{
  "name": "n8n-nodes-oura-v2",
  "version": "0.1.2",
  "description": "n8n community node for the Oura Ring v2 API with OAuth2 authentication. Get readiness, activity and personal info data from your Oura Ring.",
  "license": "MIT",
  "homepage": "https://github.com/inkku/n8n-oura-v2",
  "keywords": [
    "n8n-community-node-package",
    "oura",
    "oura-ring",
    "health",
    "readiness",
    "sleep",
    "wellness",
    "wearable"
  ],
  "author": {
    "name": "inkku",
    "email": "iekmannn@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inkku/n8n-oura-v2.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/OuraV2OAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/OuraV2/OuraV2.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
